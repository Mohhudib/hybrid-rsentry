# Backend
POSTGRES_PASSWORD=change-me-choose-a-strong-password
DATABASE_URL=postgresql+asyncpg://rsentry:change-me-choose-a-strong-password@localhost:5432/rsentry_db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production-use-32-chars
# HOST_ID is auto-detected from your machine's hostname — do not set this manually.
# Each user who clones this project will automatically get their own host identity.
# HOST_ID=your-machine-name

# Agent
BACKEND_URL=http://localhost:8000
# Set this to a directory OUTSIDE the project folder to avoid canary file corruption
# Example: /home/your-username/Documents
WATCH_PATH=/home/your-username/Documents
CANARY_COUNT=30
# Sensor backend — ebpf (default) requires python3-bpfcc + kernel 6.19+
# Set to inotify if BCC is not installed or kernel is too old
# SENSOR_BACKEND=inotify

# Dry run — disables actual containment actions (SIGSTOP/iptables/SIGKILL) for testing
# DRY_RUN=true
# AI Analysis — primary provider (also readable as AI_API_KEY)
NVIDIA_API_KEY=your-nvidia-or-groq-api-key-here
# AI Analysis — on-demand alerts provider (also readable as AI_API_KEY_ALERTS)
NVIDIA_API_KEY_ALERTS=your-nvidia-or-groq-api-key-here

# AI Analysis — optional Cerebras provider
# AI Analysis — optional dedicated Groq provider (alternative to passing Groq keys via NVIDIA_API_KEY slots)
# GROQ_API_KEY=gsk-your-groq-key-here
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MODEL=llama-3.3-70b-versatile
# If set, Cerebras becomes the primary provider (fastest); NVIDIA/Groq keys are used as fallback.
# Groq keys are auto-detected by the gsk_ prefix.
# AI_API_KEY_CEREBRAS=csk-your-cerebras-key-here
