*.log

# Evidence (sensitive)
/tmp/rsentry_evidence/
/tmp/rsentry_canaries/
/tmp/rsentry_test/

# IDE
.vscode/
.idea/
*.swp

# Canary files — never track these in git
# 4 prefixes (agent/graph.py, agent/monitor_ebpf.py): AAA_ aaa_ ZZZ_ zzz_
# Any extension — graph.py always uses .txt; monitor_ebpf.py seeds from
# ATTRACTIVE_EXTS (.docx .xlsx .pdf .db .vmdk). No leading slash needed:
# gitignore patterns without "/" already match at any directory depth.
AAA_*
aaa_*
ZZZ_*
zzz_*
.coverage
htmlcov/
.pytest_cache/

# Alembic
__pycache__/
